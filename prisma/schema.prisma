generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model achievements {
  id                String              @id
  code              String              @unique
  name              String
  description       String
  icon              String
  rarity            Rarity
  xpReward          Int
  condition         Json
  user_achievements user_achievements[]
}

model ai_cache_entries {
  id        String   @id
  skill     String
  inputHash String
  response  Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([skill, inputHash])
}

model ai_conversations {
  id        String   @id
  userId    String
  title     String?
  context   String?
  messages  Json     @default("[]")
  provider  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model ai_preferences {
  id                   String   @id
  userId               String   @unique
  autoGenerateStories  Boolean  @default(true)
  smartTaskSuggestions Boolean  @default(true)
  dailyBriefing        Boolean  @default(false)
  burnoutWarnings      Boolean  @default(true)
  writingAssistance    String   @default("subtle")
  narrativeTone        String   @default("epic")
  insightFrequency     String   @default("balanced")
  dailyTokenLimit      Int      @default(50000)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  users                users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ai_usage {
  id         String   @id
  userId     String
  skill      String
  tokensUsed Int
  cost       Float
  success    Boolean  @default(true)
  provider   String?
  model      String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skill, date])
  @@index([userId, date])
  @@index([userId, skill, date])
}

model areas {
  id             String           @id
  type           AreaType         @unique
  displayName    String
  icon           String
  color          String
  sortOrder      Int
  events         events[]
  goals          goals[]
  projects       projects[]
  tasks          tasks[]
  writing_pieces writing_pieces[]
}

model bosses {
  id          String     @id
  projectId   String     @unique
  name        String
  description String?
  icon        String     @default("💀")
  hp          Int
  maxHp       Int
  status      BossStatus @default(ACTIVE)
  deadline    DateTime?
  xpReward    Int        @default(500)
  lootTableId String?
  defeatedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  projects    projects   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model calendar_syncs {
  id             String    @id
  userId         String
  provider       String    @default("GOOGLE")
  email          String?
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  users          users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, email])
}

model characters {
  id               String          @id
  userId           String          @unique
  name             String
  class            CharacterClass
  level            Int             @default(1)
  xp               Int             @default(0)
  xpToNextLevel    Int             @default(250)
  hp               Int             @default(100)
  maxHp            Int             @default(100)
  energy           Int             @default(100)
  maxEnergy        Int             @default(100)
  energyRegenRate  Int             @default(20)
  status           CharacterStatus @default(ALIVE)
  diedAt           DateTime?
  deathCount       Int             @default(0)
  currentStreak    Int             @default(0)
  longestStreak    Int             @default(0)
  lastActiveAt     DateTime        @default(now())
  streakProtection Int             @default(0)
  tasksCompleted   Int             @default(0)
  bossesDefeated   Int             @default(0)
  totalXpEarned    Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  maxWeeklyEnergy  Int             @default(500)
  weekStartDate    DateTime        @default(now())
  weeklyEnergy     Int             @default(500)
  users            users           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model daily_challenges {
  id          String        @id
  userId      String
  type        ChallengeType
  description String
  target      Int           @default(1)
  progress    Int           @default(0)
  completed   Boolean       @default(false)
  xpReward    Int           @default(75)
  date        DateTime      @default(now()) @db.Date
  users       users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, date])
}

model events {
  id               String          @id
  userId           String
  areaId           String
  title            String
  description      String?
  location         String?
  startsAt         DateTime
  endsAt           DateTime
  allDay           Boolean         @default(false)
  googleEventId    String?         @unique
  lastSyncedAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  bossDamage       Int?
  eventType        EventType       @default(ACTION_ITEM)
  googleCalendarId String?
  hpPenalty        Int?
  projectId        String?
  status           EventStatus     @default(SCHEDULED)
  xpEarned         Int?
  areas            areas           @relation(fields: [areaId], references: [id])
  projects         projects?       @relation(fields: [projectId], references: [id])
  users            users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story_entries    story_entries[]
}

model goal_entries {
  id     String   @id
  goalId String
  value  Int
  date   DateTime @db.Date
  goals  goals    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
}

model goals {
  id           String         @id
  userId       String
  areaId       String
  title        String
  cadence      String
  target       Int
  unit         String
  createdAt    DateTime       @default(now())
  goal_entries goal_entries[]
  areas        areas          @relation(fields: [areaId], references: [id])
  users        users          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model health_logs {
  id        String        @id
  userId    String
  type      HealthLogType
  value     Float?
  unit      String?
  notes     String?
  source    HealthSource  @default(MANUAL)
  loggedAt  DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime
  users     users         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model health_syncs {
  id            String         @id
  userId        String
  provider      HealthProvider
  accessToken   String?
  refreshToken  String?
  lastSyncAt    DateTime?
  workoutToday  Boolean        @default(false)
  sleepHours    Float?
  steps         Int?
  activeMinutes Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  users         users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model inventory_items {
  id         String   @id
  userId     String
  itemType   ItemType
  quantity   Int      @default(1)
  rarity     Rarity
  name       String
  icon       String
  effect     String
  acquiredAt DateTime @default(now())
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType])
}

model loot_tables {
  id    String @id
  name  String
  drops Json
}

model projects {
  id             String           @id
  userId         String
  areaId         String
  name           String
  description    String?
  status         String           @default("active")
  targetDate     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  bosses         bosses?
  events         events[]
  areas          areas            @relation(fields: [areaId], references: [id])
  users          users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          tasks[]
  writing_pieces writing_pieces[]
}

model quest_chains {
  id          String      @id
  userId      String
  title       String
  narrative   String?
  steps       Json
  currentStep Int         @default(0)
  totalSteps  Int
  status      QuestStatus @default(ACTIVE)
  xpReward    Int         @default(500)
  createdAt   DateTime    @default(now())
  completedAt DateTime?
  users       users       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       tasks[]
}

model story_entries {
  id          String         @id
  userId      String
  entryType   StoryEntryType
  title       String
  narrative   String
  eventId     String?
  xpEarned    Int?
  hpChange    Int?
  bossDamage  Int?
  aiGenerated Boolean        @default(true)
  createdAt   DateTime       @default(now())
  events      events?        @relation(fields: [eventId], references: [id])

  @@index([userId, createdAt])
}

model tags {
  id        String      @id
  name      String      @unique
  color     String?
  task_tags task_tags[]
}

model task_buckets {
  id        String   @id
  userId    String
  name      String
  color     String?
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  tasks     tasks[]

  @@unique([userId, name])
}

model task_tags {
  taskId String
  tagId  String
  tags   tags   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tasks  tasks  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model tasks {
  id             String        @id
  userId         String
  areaId         String
  projectId      String?
  title          String
  description    String?
  status         TaskStatus    @default(TODO)
  priority       Priority      @default(MEDIUM)
  energyCost     Int           @default(15)
  xpReward       Int           @default(60)
  dueDate        DateTime?
  completedAt    DateTime?
  damageDealt    Int           @default(0)
  questChainId   String?
  questStepIndex Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  bucketId       String?
  googleEventId  String?       @unique
  startsAt       DateTime?
  type           TaskType      @default(OTHER)
  task_tags      task_tags[]
  areas          areas         @relation(fields: [areaId], references: [id])
  task_buckets   task_buckets? @relation(fields: [bucketId], references: [id])
  projects       projects?     @relation(fields: [projectId], references: [id])
  quest_chains   quest_chains? @relation(fields: [questChainId], references: [id])
  users          users         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model user_achievements {
  userId        String
  achievementId String
  unlockedAt    DateTime     @default(now())
  progress      Int          @default(0)
  achievements  achievements @relation(fields: [achievementId], references: [id])
  users         users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
}

model users {
  id                String              @id
  email             String              @unique
  name              String?
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  supabaseId        String              @unique
  ai_preferences    ai_preferences?
  ai_usage          ai_usage[]
  calendar_syncs    calendar_syncs[]
  characters        characters?
  daily_challenges  daily_challenges[]
  events            events[]
  goals             goals[]
  health_logs       health_logs[]
  health_syncs      health_syncs[]
  inventory_items   inventory_items[]
  projects          projects[]
  quest_chains      quest_chains[]
  tasks             tasks[]
  user_achievements user_achievements[]
  writing_pieces    writing_pieces[]
}

model writing_pieces {
  id               String             @id
  userId           String
  areaId           String
  projectId        String?
  title            String
  type             WritingType
  status           WritingStatus      @default(IDEA)
  wordCount        Int                @default(0)
  targetWords      Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  areas            areas              @relation(fields: [areaId], references: [id])
  projects         projects?          @relation(fields: [projectId], references: [id])
  users            users              @relation(fields: [userId], references: [id], onDelete: Cascade)
  writing_sessions writing_sessions[]
}

model writing_sessions {
  id             String         @id
  writingId      String
  wordsAdded     Int
  duration       Int?
  createdAt      DateTime       @default(now())
  writing_pieces writing_pieces @relation(fields: [writingId], references: [id], onDelete: Cascade)
}

enum AreaType {
  WORK
  HOME
  WRITING
  SIDE_PROJECTS
}

enum BossStatus {
  DORMANT
  ACTIVE
  DEFEATED
  ESCAPED
}

enum ChallengeType {
  COMPLETE_TASKS
  HIGH_PRIORITY
  DEFEAT_BOSS
  WORKOUT
  WRITING
  MULTI_AREA
  EARLY_BIRD
  NIGHT_OWL
}

enum CharacterClass {
  WARRIOR
  MAGE
  ROGUE
  BARD
}

enum CharacterStatus {
  ALIVE
  DEAD
  EXHAUSTED
}

enum EventStatus {
  SCHEDULED
  COMPLETED
  CANCELED_BY_SELF
  CANCELED_BY_OTHER
  MISSED
  RESCHEDULED
}

enum EventType {
  ACTION_ITEM
  REMINDER
}

enum HealthLogType {
  WORKOUT
  STEPS
  SLEEP
  WATER
  CALORIES
  ACTIVE_MINUTES
  HEART_RATE
  WEIGHT
  MOOD
}

enum HealthProvider {
  APPLE_HEALTH
  GOOGLE_FIT
  FITBIT
}

enum HealthSource {
  MANUAL
  APPLE_HEALTH
  IOS_SHORTCUT
  GOOGLE_FIT
  FITBIT
}

enum ItemType {
  XP_SHARD
  XP_CRYSTAL
  STREAK_SHIELD
  ENERGY_POTION
  DOUBLE_XP_TOKEN
  BOSS_BANE
  HEALTH_POTION
  REVIVE_TOKEN
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum StoryEntryType {
  EVENT_COMPLETED
  EVENT_MISSED
  EVENT_CANCELED
  EVENT_RESCHEDULED
  BOSS_DAMAGE
  BOSS_DEFEATED
  LEVEL_UP
  ACHIEVEMENT
  STREAK_MILESTONE
  DAILY_SUMMARY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  SOMEDAY
  DONE
  CANCELLED
}

enum TaskType {
  DEEP_WORK
  MEETING
  APPOINTMENT
  SOCIAL
  ERRAND
  ROUTINE
  ADMIN
  CREATIVE
  LEARNING
  OTHER
}

enum WritingStatus {
  IDEA
  OUTLINING
  DRAFTING
  EDITING
  PUBLISHED
  ABANDONED
}

enum WritingType {
  STORY
  BLOG_POST
  ARTICLE
  POETRY
  OTHER
}
